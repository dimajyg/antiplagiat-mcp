# Copy to .env and fill in real values. NEVER commit the real .env.
# On the public server this file lives ONLY at /opt/antiplagiat-mcp/.env (chmod 600).
# Clients pass their own keys via MCP request headers — these env vars are
# only used as a server-side fallback for local testing.

# Embeddings (OpenAI-compatible endpoint on OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-replace-me
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Web search for plagiarism (https://serper.dev — 2500 free credits)
SERPER_API_KEY=replace-me

# Optional: paid AI detector for deep mode
SAPLING_API_KEY=
GPTZERO_API_KEY=

# Server
HOST=0.0.0.0
PORT=8765
LOG_LEVEL=INFO

# Local model paths (resolved relative to project root if not absolute)
MODELS_DIR=./models
CACHE_DB=./cache.sqlite
